    "bench": "node test/benchmark.js",
    "prepublishOnly": "npm test"
  },
  "publishConfig": {
    "access": "public"
  },
  "gypfile": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marinopark/grep.git"
  },
  "bugs": {
