  "description": "SIMD-accelerated native C binary pattern search for Node.js Buffers. 11x faster than Buffer.indexOf loops.",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "install": "node-gyp rebuild",
    "build": "node-gyp build",
    "build:debug": "node-gyp build --debug",
